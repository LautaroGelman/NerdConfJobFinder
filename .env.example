# ─────────────────────────────────────────────────────────────
# FRONT (Next.js / Vercel) — estas SÍ van al cliente, son públicas
# Copiá este archivo a .env.local y completá los valores.
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...la-anon-key-publica...
# Username del bot SIN @ (ej: mis_ofertas_ar_bot). Para armar el link t.me/...?start=
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=mi_bot

# ─────────────────────────────────────────────────────────────
# EDGE FUNCTIONS (Supabase) — NO van en este archivo en producción.
# Se cargan con:  supabase secrets set CLAVE=valor
# Se listan acá sólo como referencia de qué hace falta.
#   DEEPSEEK_API_KEY       -> API key de DeepSeek (platform.deepseek.com)
#   TELEGRAM_BOT_TOKEN     -> token del bot (te lo da @BotFather)
#   TELEGRAM_WEBHOOK_SECRET -> string aleatorio que vos elegís (anti-spoof del webhook)
# SUPABASE_URL y SUPABASE_SERVICE_ROLE_KEY los inyecta Supabase automáticamente.
# ─────────────────────────────────────────────────────────────
